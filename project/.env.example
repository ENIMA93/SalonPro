# Supabase – use the same project as in Supabase Dashboard
# Get both values from: Dashboard → Settings → API

# Project URL (e.g. https://YOUR_PROJECT_REF.supabase.co)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon public key only (long JWT starting with eyJ...). Do NOT use service_role in the frontend.
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# If you get "Failed to fetch" on login: add this app URL to Supabase:
# Dashboard → Authentication → URL Configuration → Redirect URLs: http://localhost:5176
# (and Site URL if you use it, e.g. http://localhost:5176)
